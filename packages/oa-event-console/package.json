{
  "name": "oa-event-console",
  "version": "5.0.4",
  "private": true,
  "description": "Event Console, like a panther",
  "type": "commonjs",
  "main": "app.js",
  "engines": {
    "node": "^24.0.0"
  },
  "scripts": {
    "start": "NODE_ENV=production node dist.js",
    "build": "npm run build:fonts && npm run build:vendor && npm run build:backend && npm run build:frontend",
    "build:backend": "rimraf dist && tsc -p tsconfig.json",
    "build:frontend": "vite build",
    "build:frontend:watch": "vite build --watch",
    "build:fonts": "node scripts/unzip-fonts.js",
    "build:vendor": "node scripts/copy-vendor.js",
    "install-deps": "npm run build:fonts && npm run build:vendor",
    "dev": "concurrently \"tsc -p tsconfig.json --watch\" \"vite build --watch\"",
    "setup": "npm run setup/severity && npm run setup/default-admin",
    "setup/severity": "node dist/bin/setup_severity -c config.yml",
    "setup/default-admin": "node dist/bin/setup_user -c config.yml --user admin --group admin --password admin --email admin@example.com",
    "test": "npm run unit && npm run integration && npm run e2e",
    "unit": "mocha $NPM_MOCHA_OPTS test/unit/**/*_spec.ts",
    "integration": "mocha $NPM_MOCHA_OPTS test/int test/int/*_spec.ts",
    "coverage:unit": "c8 --no-clean mocha $NPM_MOCHA_OPTS test/unit/**/*_spec.ts",
    "coverage:integration": "c8 --no-clean mocha $NPM_MOCHA_OPTS test/int test/int/*_spec.ts",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:install": "playwright install chromium firefox",
    "build:swagger:development": "swagger-jsdoc -o swagger.development.json -d ./swaggerDevelopment.js dist/app/route/*.js dist/app/route/api/*.js dist/app/route/api/event/*.js",
    "build:swagger:production": "swagger-jsdoc -o swagger.production.json -d ./swaggerProduction.js dist/app/route/*.js dist/app/route/api/*.js dist/app/route/api/event/*.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenAnswers/panther.git"
  },
  "keywords": [
    "event",
    "alert",
    "web",
    "console"
  ],
  "author": "OpenAnswers <support+panther@openanswers.co.uk>",
  "license": "CPAL-1.0",
  "homepage": "https://openanswers.co.uk",
  "dependencies": {
    "@hapi/joi": "^16.1.0",
    "bluebird": "^3.5.1",
    "body-parser": "1.20.3",
    "bootstrap": "^3.4.1",
    "bootstrap-3-typeahead": "4.0.2",
    "clipboard": "^1.7.1",
    "color": "4.2.3",
    "connect-mongo": "4.6.0",
    "cookie-parser": "~1.4.0",
    "d3": "^3.5.17",
    "debug": "4.3.4",
    "del": "^5.1.0",
    "eventemitter2": "~0.4.14",
    "express": "5.0.1",
    "express-list-endpoints": "^4.0.1",
    "express-session": "1.19.0",
    "feedparser": "~1.1.4",
    "file-saver": "^2.0.5",
    "fs-extra": "^7.0.0",
    "glob": "^10.5.0",
    "jquery": "3.7.1",
    "jquery-ui": "^1.14.2",
    "js-yaml": "3.14.2",
    "jstransformer-markdown-it": "3.0.0",
    "less": "4.2.1",
    "lodash": "4.18.1",
    "marked": "4.0.18",
    "minimist": "1.2.8",
    "mkdirp": "1.0.4",
    "moment": "2.30.1",
    "mongoose": "=6.13.6",
    "mustache": "^4.2.0",
    "needle": "3.1.0",
    "nodemailer": "8.0.5",
    "oa-errors": "^5.0.4",
    "oa-event-rules": "^5.0.4",
    "oa-helpers": "^5.0.4",
    "oa-logging": "^5.0.4",
    "oa-tinycache": "^5.0.4",
    "passport": "0.7.0",
    "passport-local": "1.0.0",
    "passport-local-mongoose": "9.0.1",
    "passport.socketio": "3.7.0",
    "pug": "3.0.3",
    "sanitize-filename": "^1.6.1",
    "serve-favicon": "~2.5.0",
    "socket.io": "4.7.5",
    "socketio-file-upload": "^0.7.3",
    "swagger-jsdoc": "^4.0.0",
    "swagger-ui-express": "^4.1.4",
    "timeago": "^1.6.7",
    "urijs": "^1.19.11",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bluebird": "^3.5.4",
    "@types/body-parser": "^1.16.3",
    "@types/chai": "^5.0.0",
    "@types/cookie-parser": "^1.4.3",
    "@types/express": "^4.11.1",
    "@types/express-session": "0.0.32",
    "@types/lodash": "^4.14.181",
    "@types/minimist": "^1.2.0",
    "@types/mocha": "^10.0.0",
    "@types/moment": "^2.13.0",
    "@types/node": "^24.0.0",
    "@types/node-uuid": "0.0.28",
    "@types/passport": "^0.3.3",
    "@types/passport-local": "^1.0.35",
    "@types/pug": "^2.0.6",
    "@types/serve-favicon": "^2.5.0",
    "@types/sinon": "^17.0.0",
    "@vitest/ui": "^4.1.4",
    "adm-zip": "^0.5.10",
    "chai": "5.1.0",
    "concurrently": "^8.0.0",
    "eslint": "8.57.1",
    "eslint-plugin-filenames": "^1.2.0",
    "eslint-plugin-import": "^2.3.0",
    "eslint-plugin-lodash": "^2.4.2",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-promise": "6.0.0",
    "jquery-migrate": "3.5.2",
    "jsdom": "^29.0.2",
    "mocha": "^11.0.0",
    "mongodb-memory-server": "^10.0.0",
    "nock": "13.2.8",
    "rimraf": "^3.0.2",
    "sinon": "19.0.0",
    "socket.io-client": "4.7.5",
    "supertest": "6.3.3",
    "tough-cookie": "4.1.3",
    "ts-node": "^10.9.0",
    "tsx": "^4.19.0",
    "typescript": "5.7.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.4",
    "winston-spy": "^0.2.0"
  }
}
