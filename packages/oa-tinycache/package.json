{
  "name": "oa-tinycache",
  "version": "5.0.4",
  "private": true,
  "description": "A tiny cache",
  "type": "commonjs",
  "main": "lib/tiny_cache.js",
  "engines": {
    "node": "^24.0.0"
  },
  "files": [
    "lib/*.js"
  ],
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "npm run compile && mocha $MOCHA_OPTS test/unit/*_spec.ts",
    "coverage:unit": "npm run compile && c8 --no-clean mocha $MOCHA_OPTS test/unit/*_spec.ts",
    "build": "rimraf lib && tsc",
    "compile": "tsc",
    "pack": "mkdir -p pkg && npm run build && cd pkg && npm pack ../",
    "check_git_status": "git=$(git status --porcelain) && [ -z \"$git\" ] || ( echo \"git[$git]\"; exit 1 )"
  },
  "keywords": [
    "cache",
    "tiny",
    "oa",
    "openanswers"
  ],
  "author": "OpenAnswers <support+panther@openanswers.co.uk>",
  "license": "CPAL-1.0",
  "devDependencies": {
    "chai": "5.1.0",
    "mocha": "^11.0.0",
    "rimraf": "^3.0.2",
    "tsx": "^4.19.0"
  },
  "dependencies": {
    "debug": "4.3.4"
  }
}
