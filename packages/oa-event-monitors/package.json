{
  "name": "oa-event-monitors",
  "type": "commonjs",
  "description": "OpenAnswers Event Monitors",
  "version": "5.0.4",
  "private": true,
  "author": "OpenAnswers <support+panther@openanswers.co.uk>",
  "homepage": "http://openanswers.co.uk/",
  "engines": {
    "node": "^24.0.0"
  },
  "scripts": {
    "auditx": "npm audit --registry=https://registry.npmjs.org",
    "start": "concurrently npm:start/*",
    "test": "npm run unit",
    "unit": "mocha test/unit test/unit/*_spec.ts test/unit/*/*_spec.ts",
    "coverage:unit": "c8 --no-clean mocha test/unit test/unit/*_spec.ts test/unit/*/*_spec.ts",
    "syslogd": "node bin/oamon.js --name syslogd",
    "sample": "node bin/oamon.js --name sample",
    "start/http": "node bin/oamon.js --name http",
    "start/syslogd": "node bin/oamon.js --name syslogd",
    "pack": "cd ./pkg && npm pack ../",
    "nexus": "npm test && git=$(git status --porcelain) && [ -z \"$git\" ] && npm version patch && npm publish && git push && git push --tags",
    "nexus-testing": "npm test && npm version prerelease && git push && git push --tags && npm publish --tag testing",
    "tag_current": "version=$(node -e 'console.log(require(\"./package.json\").version)') && git tag v${version} && git push --tags"
  },
  "dependencies": {
    "ajv": "^6.12.6",
    "ajv-errors": "^1.0.1",
    "async": "^0.9.0",
    "bluebird": "~3.0.6",
    "body-parser": "1.20.3",
    "carrier": "0.3.0",
    "debug": "4.3.4",
    "eventemitter2": "~0.4.14",
    "express": "5.0.1",
    "glossy": "~0.1.7",
    "imap": "~0.8.14",
    "iniparser": "1.0.3",
    "joose": "3.50.0",
    "js-yaml": "3.14.2",
    "libxmljs2": "0.37.0",
    "lodash": "4.18.1",
    "minimist": "1.2.8",
    "moment": "2.30.1",
    "nconf": "0.12.0",
    "needle": "~0.11.0",
    "oa-errors": "^5.0.4",
    "oa-event-rules": "^5.0.4",
    "oa-logging": "^5.0.4",
    "oa-tinycache": "^5.0.4",
    "passport": "^0.7.0",
    "socket.io-client": "4.7.1",
    "tailfd": "~0.1.6",
    "toolkit": "~1.5.4"
  },
  "keywords": [
    "oamon",
    "monitoring",
    "event",
    "console",
    "network",
    "management",
    "alert"
  ],
  "license": "CPAL-1.0",
  "devDependencies": {
    "chai": "5.1.0",
    "concurrently": "^5.2.0",
    "eslint": "8.57.1",
    "eslint-plugin-import": "^2.7.0",
    "eslint-plugin-lodash": "^2.4.5",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-promise": "^3.5.0",
    "mocha": "^11.0.0",
    "nock": "13.2.8",
    "sinon": "19.0.0",
    "supertest": "^6.3.3",
    "tsx": "^4.19.0"
  }
}
