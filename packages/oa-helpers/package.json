{
  "name": "oa-helpers",
  "version": "5.0.4",
  "private": true,
  "description": "OA Helper methods",
  "type": "commonjs",
  "main": "lib/helpers.js",
  "engines": {
    "node": "^24.0.0"
  },
  "files": [
    "lib/*.js"
  ],
  "scripts": {
    "test": "npm run compile && mocha test/*_spec.ts",
    "coverage:unit": "npm run compile && c8 --no-clean mocha test/*_spec.ts",
    "compile": "tsc",
    "pack": "npm run build && cd pkg && npm pack ../",
    "build": "rimraf lib && tsc",
    "check_git_status": "git=$(git status --porcelain) && [ -z \"$git\" ] || ( echo \"git[$git]\"; exit 1)"
  },
  "keywords": [
    "oa",
    "openanswers",
    "helpers"
  ],
  "author": "OpenAnswers <support+panther@openanswers.co.uk>",
  "license": "CPAL-1.0",
  "devDependencies": {
    "chai": "5.1.0",
    "mocha": "^11.0.0",
    "rimraf": "^3.0.2",
    "tsx": "^4.19.0"
  },
  "dependencies": {
    "bluebird": "~3.3.5",
    "debug": "4.3.4",
    "lodash": "4.18.1",
    "uuid": "^11.0.0"
  }
}
