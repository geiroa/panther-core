USER=$1
VIEW=$2
COLUMN=$3

echo "db.viewlayouts.update( { name:'$VIEW', user: '$USER', system:false }, { \$push: { columns: { field:'$COLUMN', width:'100px' } } }, true, true ) " | mongo oa

