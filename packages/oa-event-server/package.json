{
  "name": "oa-event-server",
  "type": "commonjs",
  "description": "OpenAnswers Event Server",
  "version": "5.0.4",
  "private": true,
  "author": "OpenAnswers <support+panther@openanswers.co.uk>",
  "homepage": "http://openanswers.co.uk/",
  "scripts": {
    "migrate:up": "npx migrate-mongo up",
    "migrate:down": "npx migrate-mongo down",
    "auditx": "npm audit --registry=https://registry.npmjs.org",
    "start": "node lib/server.js",
    "test": "npm run unit && npm run integration",
    "unit": "mocha test/unit test/unit/*_spec.ts",
    "integration": "mocha $NPM_MOCHA_OPTS test/int test/int/*_spec.ts",
    "coverage:unit": "c8 --no-clean mocha test/unit test/unit/*_spec.ts",
    "coverage:integration": "c8 --no-clean mocha $NPM_MOCHA_OPTS test/int test/int/*_spec.ts",
    "pack": "cd ./pkg && npm pack ../",
    "nexus": "npm test && git=$(git status --porcelain) && [ -z \"$git\" ] && npm version patch && npm publish && git push && git push --tags",
    "nexus-testing": "npm test && npm version prerelease && git push && git push --tags && npm publish --tag testing",
    "tag_current": "version=$(node -e 'console.log(require(\"./package.json\").version)') && git tag v${version} && git push --tags"
  },
  "dependencies": {
    "async": "^1.5",
    "bluebird": "~3.0.6",
    "body-parser": "1.20.3",
    "connect": "3.7.0",
    "cookie-parser": "^1.4.6",
    "eventemitter2": "~0.4",
    "express": "5.0.1",
    "express-session": "1.19.0",
    "hooks": "^0.3.2",
    "joose": "^3.50.0",
    "lodash": "4.18.1",
    "migrate-mongo": "~10.0.0",
    "minimist": "1.2.8",
    "mongoose": "=6.13.6",
    "multiparty": "^4.1.1",
    "nconf": "0.12.0",
    "needle": "^1.6.0",
    "oa-errors": "^5.0.4",
    "oa-event-rules": "^5.0.4",
    "oa-logging": "^5.0.4",
    "opts": "^1.2.2",
    "socket.io": "4.7.1",
    "socket.io-client": "4.7.1",
    "underscore": "1.13.8"
  },
  "keywords": [
    "mongodb",
    "event",
    "console",
    "network",
    "management",
    "alert",
    "panther"
  ],
  "engines": {
    "node": "^24.0.0"
  },
  "license": "CPAL-1.0",
  "devDependencies": {
    "@types/bluebird": "^3.5.4",
    "@types/body-parser": "^1.16.3",
    "@types/express": "^4.0.35",
    "@types/express-session": "0.0.32",
    "@types/lodash": "^4.14.181",
    "@xmldom/xmldom": "0.9.10",
    "chai": "5.1.0",
    "eslint": "8.57.1",
    "eslint-plugin-filenames": "^1.2.0",
    "eslint-plugin-import": "^2.8.0",
    "eslint-plugin-lodash": "^2.5.0",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-promise": "^3.5.0",
    "grunt": "1.5.3",
    "mocha": "^11.0.0",
    "mongodb-memory-server": "^10.0.0",
    "sinon": "19.0.0",
    "supertest": "6.3.3",
    "tsx": "^4.19.0",
    "typescript": "5.7.3"
  }
}
